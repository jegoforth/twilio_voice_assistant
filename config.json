{
  "name": "Twilio Voice Assistant",
  "version": "1.0.0",
  "slug": "twilio_voice_assistant",
  "description": "Webhook service for Twilio phone calls, PIN authentication, Whisper STT, and Home Assistant AI integration.",
  "arch": ["amd64", "aarch64"],
  "startup": "services",
  "boot": "auto",
  "ports": {
    "8000/tcp": 8000
  },
  "ports_description": {
    "8000/tcp": "FastAPI webhook server"
  },
  "webui": "http://[HOST]:[PORT:8000]/admin",
  "map": ["share:rw"],
  "options": {
    "twilio_account_sid": "",
    "twilio_auth_token": "",
    "eleven_api_key": "",
    "eleven_voice_id": "",
    "public_base_url": "",
    "debug": false
  },
  "schema": {
    "twilio_account_sid": "str",
    "twilio_auth_token": "password",
    "eleven_api_key": "password",
    "eleven_voice_id": "str",
    "public_base_url": "url",
    "debug": "bool?"
  },
  "homeassistant_api": true,
  "hassio_api": true,
  "hassio_role": "default"
}
