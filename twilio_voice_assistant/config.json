{
  "name": "Twilio Voice Assistant",
  "version": "1.4.3",
  "slug": "twilio_voice_assistant",
  "description": "Twilio Conversation Relay webhook service with Caller Access authentication, DTMF PIN fallback, ElevenLabs voice support, and Home Assistant Conversation integration.",
  "arch": ["amd64", "aarch64"],
  "startup": "services",
  "boot": "auto",
  "ports": {
    "8000/tcp": 8000
  },
  "ports_description": {
    "8000/tcp": "FastAPI webhook server"
  },
  "ingress": true,
  "ingress_port": 8000,
  "ingress_entry": "/admin",
  "panel_admin": true,
  "map": ["share:rw"],
  "options": {
    "twilio_account_sid": "",
    "twilio_auth_token": "",
    "public_base_url": "",
    "auth_mode": "pin",
    "unknown_caller_policy": "reject",
    "callers": [],
    "conversation_relay_tts_provider": "ElevenLabs",
    "conversation_relay_voice": "",
    "conversation_relay_transcription_provider": "Deepgram",
    "conversation_relay_language": "en-US",
    "allow_unsigned_twilio_requests_for_dev": false,
    "debug": false
  },
  "schema": {
    "twilio_account_sid": "str",
    "twilio_auth_token": "password",
    "public_base_url": "str",
    "auth_mode": "list(caller_whitelist|pin|caller_whitelist_or_pin)?",
    "unknown_caller_policy": "list(reject|pin_fallback)?",
    "callers": [
      {
        "name": "str?",
        "phone_number": "str?",
        "phone_numbers": ["str?"],
        "ha_user_id": "str",
        "pin": "str?"
      }
    ],
    "conversation_relay_tts_provider": "list(ElevenLabs|Google|Amazon)?",
    "conversation_relay_voice": "str?",
    "conversation_relay_transcription_provider": "str?",
    "conversation_relay_language": "str?",
    "allow_unsigned_twilio_requests_for_dev": "bool?",
    "debug": "bool?"
  },
  "homeassistant_api": true,
  "hassio_api": true,
  "hassio_role": "default"
}
