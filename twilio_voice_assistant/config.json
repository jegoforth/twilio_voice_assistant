{
  "name": "Twilio Voice Assistant",
  "version": "1.3.5",
  "slug": "twilio_voice_assistant",
  "description": "Twilio webhook service with caller whitelist/PIN fallback authentication, Gather compatibility mode, experimental Conversation Relay text-only bridge, and Home Assistant Conversation integration.",
  "arch": ["amd64", "aarch64"],
  "startup": "services",
  "boot": "auto",
  "ports": {
    "8000/tcp": 8000
  },
  "ports_description": {
    "8000/tcp": "FastAPI webhook server"
  },
  "ingress": true,
  "ingress_port": 8000,
  "ingress_entry": "/admin",
  "panel_admin": true,
  "map": ["share:rw"],
  "options": {
    "twilio_account_sid": "",
    "twilio_auth_token": "",
    "public_base_url": "",
    "auth_mode": "pin",
    "unknown_caller_policy": "reject",
    "allowed_callers": [],
    "voice_bridge_mode": "gather",
    "conversation_relay_tts_provider": "ElevenLabs",
    "conversation_relay_voice": "",
    "conversation_relay_transcription_provider": "Deepgram",
    "conversation_relay_language": "en-US",
    "pin_mode": "dtmf",
    "debug": false
  },
  "schema": {
    "twilio_account_sid": "str",
    "twilio_auth_token": "password",
    "public_base_url": "str",
    "auth_mode": "list(caller_whitelist|pin|caller_whitelist_or_pin)?",
    "unknown_caller_policy": "list(reject|pin_fallback)?",
    "allowed_callers": [
      {
        "name": "str",
        "phone_number": "str?",
        "phone_numbers": ["str?"],
        "ha_user_id": "str"
      }
    ],
    "voice_bridge_mode": "list(gather|conversation_relay|elevenlabs_agent)?",
    "conversation_relay_tts_provider": "str?",
    "conversation_relay_voice": "str?",
    "conversation_relay_transcription_provider": "str?",
    "conversation_relay_language": "str?",
    "pin_mode": "list(dtmf|speech)?",
    "debug": "bool?"
  },
  "homeassistant_api": true,
  "hassio_api": true,
  "hassio_role": "default"
}
